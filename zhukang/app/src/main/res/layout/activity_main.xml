<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zk_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:paddingBottom="188dp"
        tools:context=".MainActivity">

        <!-- 标题 -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="筑康NutriNest"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/zk_text_primary"
            app:layout_constraintEnd_toStartOf="@id/btnLanguageToggle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/btnLanguageToggle"
            android:layout_width="68dp"
            android:layout_height="36dp"
            android:backgroundTint="@color/zk_secondary"
            android:text="EN"
            android:textColor="@color/zk_text_primary"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/tvTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvTitle" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="选择餐次后拍照，自动更新今日累计营养"
            android:textSize="14sp"
            android:textColor="@color/zk_text_secondary"
            android:layout_marginTop="6dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvTitle"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <!-- 餐次选择区 -->
        <LinearLayout
            android:id="@+id/mealTypeSelector"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="14dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

            <Button
                android:id="@+id/btnBreakfast"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="早餐"
                android:textSize="14sp"
                android:background="@drawable/bg_meal_chip_unselected"
                android:stateListAnimator="@null"
                android:textColor="@color/zk_text_primary" />

            <Button
                android:id="@+id/btnLunch"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="午餐"
                android:textSize="14sp"
                android:background="@drawable/bg_meal_chip_unselected"
                android:stateListAnimator="@null"
                android:textColor="@color/zk_text_primary" />

            <Button
                android:id="@+id/btnDinner"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="晚餐"
                android:textSize="14sp"
                android:background="@drawable/bg_meal_chip_unselected"
                android:stateListAnimator="@null"
                android:textColor="@color/zk_text_primary" />

            <Button
                android:id="@+id/btnSnack"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="加餐"
                android:textSize="14sp"
                android:background="@drawable/bg_meal_chip_unselected"
                android:stateListAnimator="@null"
                android:textColor="@color/zk_text_primary" />

        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardQuickActions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/zk_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/zk_divider"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/mealTypeSelector">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tvQuickActionsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="快捷操作"
                    android:textColor="@color/zk_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnTakePhoto"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:backgroundTint="@color/zk_primary"
                        android:drawableStart="@android:drawable/ic_menu_camera"
                        android:drawablePadding="6dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:text="拍照识别"
                        android:textColor="@color/zk_on_primary"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btnPickImage"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:backgroundTint="@color/zk_secondary"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:text="相册导入"
                        android:textColor="@color/zk_text_primary"
                        android:textSize="14sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnRecommend"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="@color/zk_primary"
                    android:text="下一餐智能推荐"
                    android:textColor="@color/zk_on_primary"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 图片预览区域 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/zk_surface"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/cardQuickActions">

            <ImageView
                android:id="@+id/ivFoodImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="食物图片" />
        </androidx.cardview.widget.CardView>

        <!-- 加载进度条 -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="32dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardImage" />

        <!-- 结果卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/zk_surface"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/cardImage">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- 食物名称 -->
                <TextView
                    android:id="@+id/tvFoodName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="食物名称"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/zk_text_primary" />

                <!-- 分隔线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/zk_divider"
                    android:layout_marginVertical="16dp" />

                <!-- 营养素网格 -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2">

                    <!-- 热量 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:padding="8dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvCaloriesLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="热量"
                            android:textSize="12sp"
                            android:textColor="@color/zk_text_secondary" />

                        <TextView
                            android:id="@+id/tvCalories"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="@color/zk_nutrient_calories" />

                        <TextView
                            android:id="@+id/tvCaloriesUnit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="千卡"
                            android:textSize="12sp"
                            android:textColor="@color/zk_text_secondary" />
                    </LinearLayout>

                    <!-- 蛋白质 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:padding="8dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvProteinLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="蛋白质"
                            android:textSize="12sp"
                            android:textColor="@color/zk_text_secondary" />

                        <TextView
                            android:id="@+id/tvProtein"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="@color/zk_nutrient_protein" />

                        <TextView
                            android:id="@+id/tvProteinUnit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="克"
                            android:textSize="12sp"
                            android:textColor="@color/zk_text_secondary" />
                    </LinearLayout>

                    <!-- 脂肪 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:padding="8dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvFatLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="脂肪"
                            android:textSize="12sp"
                            android:textColor="@color/zk_text_secondary" />

                        <TextView
                            android:id="@+id/tvFat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="@color/zk_nutrient_fat" />

                        <TextView
                            android:id="@+id/tvFatUnit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="克"
                            android:textSize="12sp"
                            android:textColor="@color/zk_text_secondary" />
                    </LinearLayout>

                    <!-- 碳水 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:padding="8dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvCarbsLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="碳水"
                            android:textSize="12sp"
                            android:textColor="@color/zk_text_secondary" />

                        <TextView
                            android:id="@+id/tvCarbs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="@color/zk_nutrient_carbs" />

                        <TextView
                            android:id="@+id/tvCarbsUnit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="克"
                            android:textSize="12sp"
                            android:textColor="@color/zk_text_secondary" />
                    </LinearLayout>

                </GridLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 今日饮食进度卡片（点击切换百分比/绝对值） -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardDayProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:visibility="gone"
            app:cardBackgroundColor="@color/zk_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/cardResult">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvDayProgressTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="今日累计进度"
                    android:textColor="@color/zk_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvProgressModeHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="今日累计百分比（点按切换）"
                    android:textColor="@color/zk_text_secondary"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDayCaloriesLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="热量"
                        android:textColor="@color/zk_text_secondary"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvDayCaloriesValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0%"
                            android:textColor="@color/zk_nutrient_calories"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/ivDayCaloriesWarning"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:contentDescription="超量警示"
                            android:src="@drawable/alert_red"
                            android:visibility="gone" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp">

                        <ProgressBar
                            android:id="@+id/pbDayCalories"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="8dp"
                            android:max="100"
                            android:progress="0"
                            android:progressBackgroundTint="@color/zk_progress_track"
                            android:progressTint="@color/zk_nutrient_calories" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvDayProteinLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="蛋白质"
                        android:textColor="@color/zk_text_secondary"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvDayProteinValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0%"
                            android:textColor="@color/zk_nutrient_protein"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/ivDayProteinWarning"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:contentDescription="超量警示"
                            android:src="@drawable/alert_red"
                            android:visibility="gone" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp">

                        <ProgressBar
                            android:id="@+id/pbDayProtein"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="8dp"
                            android:max="100"
                            android:progress="0"
                            android:progressBackgroundTint="@color/zk_progress_track"
                            android:progressTint="@color/zk_nutrient_protein" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvDayFatLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="脂肪"
                        android:textColor="@color/zk_text_secondary"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvDayFatValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0%"
                            android:textColor="@color/zk_nutrient_fat"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/ivDayFatWarning"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:contentDescription="超量警示"
                            android:src="@drawable/alert_red"
                            android:visibility="gone" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp">

                        <ProgressBar
                            android:id="@+id/pbDayFat"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="8dp"
                            android:max="100"
                            android:progress="0"
                            android:progressBackgroundTint="@color/zk_progress_track"
                            android:progressTint="@color/zk_nutrient_fat" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvDayCarbsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="碳水"
                        android:textColor="@color/zk_text_secondary"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvDayCarbsValue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0%"
                            android:textColor="@color/zk_nutrient_carbs"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/ivDayCarbsWarning"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:contentDescription="超量警示"
                            android:src="@drawable/alert_red"
                            android:visibility="gone" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp">

                        <ProgressBar
                            android:id="@+id/pbDayCarbs"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="8dp"
                            android:max="100"
                            android:progress="0"
                            android:progressBackgroundTint="@color/zk_progress_track"
                            android:progressTint="@color/zk_nutrient_carbs" />
                    </FrameLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 错误信息 -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/zk_error"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/cardDayProgress" />

    </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <include layout="@layout/layout_bottom_nav" />

</FrameLayout>
