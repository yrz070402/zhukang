<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zk_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="182dp">

        <!-- 顶部返回栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="返回"
                android:padding="8dp"
                android:src="@android:drawable/ic_media_previous"
                android:tint="@color/zk_text_primary" />

            <TextView
                android:id="@+id/tvPageTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="个人资料"
                android:textColor="@color/zk_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvPageSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="编辑后将同步更新健康目标"
            android:textColor="@color/zk_text_secondary"
            android:textSize="13sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/zk_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="92dp"
                    android:layout_height="112dp"
                    android:contentDescription="用户头像"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_launcher_foreground" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAccount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="账号：--"
                        android:textColor="@color/zk_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvNicknameLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="昵称:"
                        android:textColor="@color/zk_text_secondary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvNicknameValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:minHeight="48dp"
                        android:paddingStart="10dp"
                        android:paddingTop="12dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="12dp"
                        android:text="点击输入昵称"
                        android:textColor="@color/zk_text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etNicknameEdit"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:hint="请输入昵称"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/btnChangeAvatar"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="@color/zk_secondary"
                        android:text="切换头像"
                        android:textColor="@color/zk_text_primary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/zk_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvBasicInfoTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="基础信息"
                    android:textColor="@color/zk_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAgeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="年龄（岁）"
                    android:textColor="@color/zk_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvAgeValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:minHeight="44dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:text="点击填写年龄"
                    android:textColor="@color/zk_text_primary"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/etAgeEdit"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="请输入年龄（1-120）"
                    android:inputType="number"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvHeightLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="身高（cm）"
                    android:textColor="@color/zk_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvHeightValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:minHeight="44dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:text="点击填写身高"
                    android:textColor="@color/zk_text_primary"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/etHeightEdit"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="请输入身高，例如 170"
                    android:inputType="numberDecimal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvWeightLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="体重（kg）"
                    android:textColor="@color/zk_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvWeightValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:minHeight="44dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:text="点击填写体重"
                    android:textColor="@color/zk_text_primary"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/etWeightEdit"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="请输入体重，例如 65.5"
                    android:inputType="numberDecimal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvGenderTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="性别"
                    android:textColor="@color/zk_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgGender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbGenderMale"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="男" />

                    <RadioButton
                        android:id="@+id/rbGenderFemale"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:text="女" />
                </RadioGroup>

                <TextView
                    android:id="@+id/tvActivityLevelValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="运动量：轻度活动"
                    android:textColor="@color/zk_text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderActivityLevel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:stepSize="1"
                    android:value="1"
                    android:valueFrom="0"
                    android:valueTo="3" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/zk_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvGoalSectionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="目标与配额"
                    android:textColor="@color/zk_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgGoalType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbGoalMuscle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="活力塑型" />

                    <RadioButton
                        android:id="@+id/rbGoalFatLoss"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="轻松减脂" />

                    <RadioButton
                        android:id="@+id/rbGoalMaintain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="健康养成" />
                </RadioGroup>

                <TextView
                    android:id="@+id/tvGoalCaloriesLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="目标卡路里（kcal）"
                    android:textColor="@color/zk_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvTargetCaloriesValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:minHeight="44dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:text="点击填写目标卡路里"
                    android:textColor="@color/zk_text_primary"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/etTargetCaloriesEdit"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="请输入目标卡路里"
                    android:inputType="numberDecimal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvGoalCarbLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="目标碳水（g）"
                    android:textColor="@color/zk_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvTargetCarbValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:minHeight="44dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:text="点击填写目标碳水"
                    android:textColor="@color/zk_text_primary"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/etTargetCarbEdit"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="请输入目标碳水"
                    android:inputType="numberDecimal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvGoalProteinLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="目标蛋白质（g）"
                    android:textColor="@color/zk_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvTargetProteinValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:minHeight="44dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:text="点击填写目标蛋白质"
                    android:textColor="@color/zk_text_primary"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/etTargetProteinEdit"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="请输入目标蛋白质"
                    android:inputType="numberDecimal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvGoalFatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="目标脂肪（g）"
                    android:textColor="@color/zk_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvTargetFatValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:minHeight="44dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:text="点击填写目标脂肪"
                    android:textColor="@color/zk_text_primary"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/etTargetFatEdit"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="请输入目标脂肪"
                    android:inputType="numberDecimal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/zk_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvTagsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="用户标签"
                    android:textColor="@color/zk_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/cgUserTags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:chipSpacingHorizontal="8dp"
                    app:chipSpacingVertical="8dp"
                    app:singleSelection="false" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etTagInput"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:hint="输入标签并添加"
                        android:inputType="textCapWords"
                        android:maxLines="1"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp" />

                    <Button
                        android:id="@+id/btnAddTag"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@color/zk_secondary"
                        android:text="添加"
                        android:textColor="@color/zk_text_primary" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/zk_primary"
            android:text="保存修改"
            android:textColor="@color/zk_on_primary"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/tvState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text=""
            android:textColor="@color/zk_text_secondary"
            android:textSize="13sp"
            android:visibility="gone" />

        </LinearLayout>

    </ScrollView>

    <include layout="@layout/layout_bottom_nav" />
</FrameLayout>
